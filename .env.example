# Engine environment — example values.
# This file documents NOTABLE vars; the engine reads many others from `.env`
# (see CLAUDE.md for the full config surface). Copy what you need into `.env`.

# --- Web-app (Clerk) auth ---------------------------------------------------
# Required for the Clara web app to authenticate directly to the engine.
# The engine validates Clerk session JWTs (RS256) against this JWKS endpoint
# and (optionally) checks the issuer.
CLERK_JWKS_URL=https://<your-clerk-subdomain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-subdomain>.clerk.accounts.dev

# CORS already allows http://localhost:5173 (the app's Vite dev server).
# Add production app origins (comma-separated) here when deploying:
# GATEWAY_API_CORS_ORIGINS=http://localhost:5173,https://app.example.com
